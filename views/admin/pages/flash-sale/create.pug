extends ../../layouts/default.pug
include ../../mixins/page-header.pug

block main
  +pageHeader("Tạo Flash Sale", "Thiết lập chương trình Flash Sale mới")

  .admin-form-card
    form(action=`${prefixAdmin}/flash-sale/create` method="POST")
      .form-row
        .form-col
          .form-group
            label.form-label Tên chương trình
              span.required *
            input.form-input(
              type="text"
              name="title"
              placeholder="VD: Flash Sale Cuối Tuần"
              required
            )

          .form-row-inline
            .form-group.form-group-half
              label.form-label Thời gian bắt đầu
                span.required *
              input.form-input(type="datetime-local" name="startTime" required)
            .form-group.form-group-half
              label.form-label Thời gian kết thúc
                span.required *
              input.form-input(type="datetime-local" name="endTime" required)

          .form-group
            label.form-label Trạng thái
            select.form-input.form-select(name="status")
              option(value="active") Hoạt động
              option(value="inactive") Dừng hoạt động

      .form-group
        label.form-label Sản phẩm trong Flash Sale
        button.btn.btn-sm.btn-add-product.mb-3#btnAddProduct(type="button")
          i.fas.fa-plus.mr-1
          | Thêm sản phẩm

        .admin-table-wrapper
          table.admin-table#flashSaleProductsTable
            thead
              tr
                th Sản phẩm
                th Giá gốc
                th Giảm giá (%)
                th Số lượng
                th Hành động
            tbody#flashSaleProductsBody

      .form-actions
        a.btn-cancel(href=`${prefixAdmin}/flash-sale`) Huỷ
        button.btn-submit(type="submit")
          i.fas.fa-plus
          |  Tạo Flash Sale

  //- Modal chọn sản phẩm
  .modal.fade#productSelectModal(tabindex="-1")
    .modal-dialog.modal-lg
      .modal-content
        .modal-header
          h5.modal-title Chọn sản phẩm
          button.close(type="button" data-dismiss="modal")
            span &times;
        .modal-body
          input.form-input.mb-3#productSearchInput(type="text" placeholder="Tìm kiếm sản phẩm...")
          .product-select-list(style="max-height: 400px; overflow-y: auto")
            each product in products
              .product-select-item.d-flex.align-items-center.p-2.border-bottom(data-id=product._id data-title=product.title data-price=product.price data-thumbnail=product.thumbnail style="cursor: pointer; transition: background 0.15s")
                if product.thumbnail
                  img.mr-3(src=product.thumbnail style="width: 50px; height: 50px; object-fit: cover; border-radius: 6px")
                else
                  .mr-3.d-flex.align-items-center.justify-content-center(style="width: 50px; height: 50px; background: var(--admin-bg, #f5f6fa); border-radius: 6px")
                    i.fas.fa-image(style="color: #bbb")
                div.flex-grow-1
                  .product-name= product.title
                  .text-muted(style="font-size: 13px")= product.price ? product.price.toLocaleString('vi-VN') + '₫' : 'Chưa có giá'
                button.btn-submit.btn-select-product(type="button" style="padding: 6px 18px; font-size: 13px") Chọn

block append scripts
  script.
    const addedProductIds = new Set();

    document.getElementById('btnAddProduct').addEventListener('click', function(e) {
      e.preventDefault();
      $('#productSelectModal').modal('show');
    });

    document.getElementById('productSearchInput').addEventListener('input', function() {
      const query = this.value.toLowerCase();
      document.querySelectorAll('.product-select-item').forEach(item => {
        const title = item.dataset.title.toLowerCase();
        item.style.display = title.includes(query) ? '' : 'none';
      });
    });

    document.querySelectorAll('.btn-select-product').forEach(btn => {
      btn.addEventListener('click', function() {
        const item = this.closest('.product-select-item');
        const id = item.dataset.id;

        if (addedProductIds.has(id)) {
          alert('Sản phẩm này đã được thêm!');
          return;
        }

        addedProductIds.add(id);
        const title = item.dataset.title;
        const price = parseInt(item.dataset.price) || 0;
        const thumbnail = item.dataset.thumbnail;

        const row = document.createElement('tr');
        row.innerHTML = `
          <td>
            <div class="d-flex align-items-center">
              ${thumbnail ? `<img src="${thumbnail}" class="mr-2" style="width: 40px; height: 40px; object-fit: cover; border-radius: 4px">` : ''}
              <span>${title}</span>
            </div>
            <input type="hidden" name="productIds" value="${id}">
          </td>
          <td>${price.toLocaleString('vi-VN')}₫</td>
          <td><input type="number" name="productDiscounts" class="form-input" value="10" min="0" max="99" style="width: 80px; padding: 6px 10px"></td>
          <td><input type="number" name="productStocks" class="form-input" value="10" min="1" style="width: 80px; padding: 6px 10px"></td>
          <td><a href="javascript:void(0)" class="hover-action-link hover-action-danger btn-remove-product" data-id="${id}">Xoá</a></td>
        `;
        document.getElementById('flashSaleProductsBody').appendChild(row);

        row.querySelector('.btn-remove-product').addEventListener('click', function() {
          addedProductIds.delete(this.dataset.id);
          row.remove();
        });

        $('#productSelectModal').modal('hide');
      });
    });

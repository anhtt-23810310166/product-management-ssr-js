extends ../../layouts/default
include ../../mixins/product-card.pug

block main
  .container.py-4
    nav(aria-label="breadcrumb")
      ol.breadcrumb.bg-transparent.px-0.pb-3.pt-0.mb-0.tz-breadcrumb-nav
        li.breadcrumb-item
          a.text-muted(href="/") Trang chủ
        li.breadcrumb-item
          a.text-muted(href="/products") Sản phẩm
        li.breadcrumb-item.active.tz-breadcrumb-active(aria-current="page") So sánh sản phẩm

    if products && products.length >= 2
      h4.font-weight-bold.mb-4
        i.fas.fa-exchange-alt.mr-2
        | So sánh #{products.length} sản phẩm

      .table-responsive
        table.table.table-bordered.tz-compare-table
          tbody
            //- Hình ảnh
            tr
              th.tz-compare-label Hình ảnh
              each product in products
                td.text-center
                  a(href=`/products/detail/${product.slug}`)
                    img.tz-compare-img(src=product.thumbnail alt=product.title)

            //- Tên SP
            tr
              th.tz-compare-label Tên sản phẩm
              each product in products
                td.text-center.font-weight-bold
                  a.text-dark(href=`/products/detail/${product.slug}`)= product.title

            //- Giá
            tr
              th.tz-compare-label Giá
              each product in products
                td.text-center
                  if product.discountPercentage > 0
                    .text-danger.font-weight-bold= product.priceNew.toLocaleString('vi-VN') + '₫'
                    small.text-muted.d-block
                      del= product.price.toLocaleString('vi-VN') + '₫'
                    small.text-success -#{product.discountPercentage}%
                  else
                    .text-danger.font-weight-bold= product.price.toLocaleString('vi-VN') + '₫'

            //- Thương hiệu
            tr
              th.tz-compare-label Thương hiệu
              each product in products
                td.text-center= product.brandName

            //- Tồn kho
            tr
              th.tz-compare-label Tình trạng
              each product in products
                td.text-center
                  if product.stock > 0
                    span.badge.badge-success Còn hàng (#{product.stock})
                  else
                    span.badge.badge-danger Hết hàng

            //- Mô tả
            tr
              th.tz-compare-label Mô tả
              each product in products
                td.small.tz-compare-desc!= product.description ? product.description.substring(0, 200) + '...' : '—'

            //- Hành động
            tr
              th.tz-compare-label
              each product in products
                td.text-center
                  if product.stock > 0
                    form(action=`/cart/add/${product._id}` method="POST" style="display:inline;")
                      input(type="hidden" name="quantity" value="1")
                      button.btn.btn-primary.btn-sm(type="submit")
                        i.fas.fa-cart-plus.mr-1
                        | Thêm giỏ hàng
                  button.btn.btn-outline-danger.btn-sm.ml-1(type="button" onclick=`removeCompare('${product._id}')`)
                    i.fas.fa-times.mr-1
                    | Bỏ

    else if products && products.length === 1
      .text-center.py-5
        i.fas.fa-exchange-alt.fa-3x.text-muted.mb-3
        h5.text-muted Cần ít nhất 2 sản phẩm để so sánh
        a.btn.btn-primary.mt-2(href="/products") Chọn thêm sản phẩm

    else
      .text-center.py-5
        i.fas.fa-exchange-alt.fa-3x.text-muted.mb-3
        h5.text-muted Chưa có sản phẩm nào để so sánh
        p.text-muted Bấm biểu tượng so sánh trên sản phẩm bạn muốn
        a.btn.btn-primary.mt-2(href="/products") Khám phá sản phẩm

  script.
    function removeCompare(id) {
      var list = JSON.parse(localStorage.getItem('compareList') || '[]');
      list = list.filter(function(item) { return item !== id; });
      localStorage.setItem('compareList', JSON.stringify(list));
      window.location.href = '/products/compare?ids=' + list.join(',');
    }

extends ../../layouts/default.pug
include ../../mixins/page-header.pug

block main
  +pageHeader("Quản lý Flash Sale", "Tạo và quản lý các chương trình Flash Sale")
    a.btn.btn-add-product(href=`${prefixAdmin}/flash-sale/create`)
      i.fas.fa-plus.mr-2
      | Tạo Flash Sale

  .admin-table-wrapper
    if flashSales && flashSales.length > 0
      table.admin-table
        thead
          tr
            th.col-stt STT
            th.col-title Tên chương trình
            th Thời gian
            th Số sản phẩm
            th Tiến trình
            th.col-status Trạng thái
            th Hành động
        tbody
          each sale, index in flashSales
            tr.animate-in
              td.col-stt= index + 1
              td.col-title
                .product-title-cell
                  span.product-name= sale.title
              td
                div
                  small.text-muted Bắt đầu:
                  |  #{new Date(sale.startTime).toLocaleString('vi-VN')}
                div
                  small.text-muted Kết thúc:
                  |  #{new Date(sale.endTime).toLocaleString('vi-VN')}
              td
                span.category-tag= sale.products.length + ' sản phẩm'
              td
                if sale.timeStatus === 'ongoing'
                  span.status-badge.status-active
                    i.fas.fa-circle.mr-1(style="font-size: 8px")
                    | Đang diễn ra
                else if sale.timeStatus === 'upcoming'
                  span.status-badge(style="background: #fff3cd; color: #856404")
                    i.fas.fa-clock.mr-1
                    | Sắp diễn ra
                else
                  span.status-badge.status-inactive
                    i.fas.fa-check.mr-1
                    | Đã kết thúc
              td.col-status
                if sale.status === "active"
                  span.status-badge.status-active Hoạt động
                else
                  span.status-badge.status-inactive Dừng hoạt động
              td
                .product-hover-actions(style="opacity: 1; visibility: visible; position: static; padding: 0")
                  a.hover-action-link.hover-action-edit(href=`${prefixAdmin}/flash-sale/edit/${sale._id}`) Sửa
                  a.hover-action-link.hover-action-danger.btn-delete-flash-sale(href="javascript:void(0)" data-id=sale._id) Xoá
    else
      .admin-empty-state
        i.fas.fa-bolt(style="font-size: 48px; color: #ddd")
        h4 Chưa có chương trình Flash Sale nào
        p Tạo Flash Sale đầu tiên để thu hút khách hàng
        a.btn.btn-add-product(href=`${prefixAdmin}/flash-sale/create`)
          i.fas.fa-plus.mr-2
          | Tạo Flash Sale

block append scripts
  script.
    document.querySelectorAll('.btn-delete-flash-sale').forEach(btn => {
      btn.addEventListener('click', async function() {
        if (!confirm('Bạn có chắc chắn muốn xóa Flash Sale này?')) return;
        const id = this.dataset.id;
        try {
          const res = await fetch(`#{prefixAdmin}/flash-sale/delete/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
          });
          const data = await res.json();
          if (data.code === 200) {
            this.closest('tr').remove();
          }
          alert(data.message);
        } catch (e) {
          alert('Có lỗi xảy ra!');
        }
      });
    });

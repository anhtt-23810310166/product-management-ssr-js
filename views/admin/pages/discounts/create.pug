extends ../../layouts/default.pug
include ../../mixins/page-header.pug

block main
  +pageHeader("Thêm mã giảm giá", "Tạo mã giảm giá mới cho khách hàng")

  .admin-form-card
    form(action=`${prefixAdmin}/discounts/create` method="POST")
      .form-row
        .form-col
          .form-group
            label.form-label Mã giảm giá
              span.required *
            input.form-input(
              type="text"
              name="code"
              placeholder="VD: SALE20, FREESHIP"
              required
              style="text-transform:uppercase;"
            )

          .form-group
            label.form-label Mô tả
            input.form-input(
              type="text"
              name="description"
              placeholder="VD: Giảm 20% cho đơn từ 500k"
            )

          .form-row-inline
            .form-group.form-group-half
              label.form-label Loại giảm giá
                span.required *
              select.form-input.form-select(name="type")
                option(value="percentage") Theo phần trăm (%)
                option(value="fixed") Số tiền cố định (₫)
            .form-group.form-group-half
              label.form-label Giá trị giảm
                span.required *
              input.form-input(type="number" name="value" required min="1" placeholder="VD: 20")

          .form-row-inline
            .form-group.form-group-half
              label.form-label Đơn hàng tối thiểu (₫)
              input.form-input(type="number" name="minOrder" value="0" min="0" placeholder="0 = không yêu cầu")
            .form-group.form-group-half
              label.form-label Giảm tối đa (₫, cho loại %)
              input.form-input(type="number" name="maxDiscount" value="0" min="0" placeholder="0 = không giới hạn")

          .form-row-inline
            .form-group.form-group-half
              label.form-label Số lần sử dụng tối đa
              input.form-input(type="number" name="usageLimit" value="0" min="0" placeholder="0 = không giới hạn")
            .form-group.form-group-half
              label.form-label Trạng thái
              select.form-input.form-select(name="status")
                option(value="active") Hoạt động
                option(value="inactive") Tạm dừng

          .form-row-inline
            .form-group.form-group-half
              label.form-label Ngày bắt đầu
                span.required *
              input.form-input(type="date" name="startDate")
            .form-group.form-group-half
              label.form-label Ngày hết hạn
                span.required *
              input.form-input(type="date" name="endDate" required)

      .form-actions
        a.btn-cancel(href=`${prefixAdmin}/discounts`) Huỷ
        button.btn-submit(type="submit")
          i.fas.fa-plus
          |  Tạo mã giảm giá

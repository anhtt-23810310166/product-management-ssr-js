extends ../../layouts/default.pug
include ../../mixins/page-header.pug

block main
  +pageHeader("Sửa mã giảm giá", `Chỉnh sửa mã ${discount.code}`)

  .admin-form-card
    form(action=`${prefixAdmin}/discounts/edit/${discount._id}?_method=PATCH` method="POST")
      .form-row
        .form-col
          .form-group
            label.form-label Mã giảm giá
              span.required *
            input.form-input(
              type="text"
              name="code"
              value=discount.code
              required
              style="text-transform:uppercase;"
            )

          .form-group
            label.form-label Mô tả
            input.form-input(
              type="text"
              name="description"
              value=discount.description
            )

          .form-row-inline
            .form-group.form-group-half
              label.form-label Loại giảm giá
                span.required *
              select.form-input.form-select(name="type")
                option(value="percentage" selected=(discount.type === "percentage")) Theo phần trăm (%)
                option(value="fixed" selected=(discount.type === "fixed")) Số tiền cố định (₫)
            .form-group.form-group-half
              label.form-label Giá trị giảm
                span.required *
              input.form-input(type="number" name="value" value=discount.value required min="1")

          .form-row-inline
            .form-group.form-group-half
              label.form-label Đơn hàng tối thiểu (₫)
              input.form-input(type="number" name="minOrder" value=discount.minOrder min="0" placeholder="0 = không yêu cầu")
            .form-group.form-group-half
              label.form-label Giảm tối đa (₫, cho loại %)
              input.form-input(type="number" name="maxDiscount" value=discount.maxDiscount min="0" placeholder="0 = không giới hạn")

          .form-row-inline
            .form-group.form-group-half
              label.form-label Số lần sử dụng tối đa
              input.form-input(type="number" name="usageLimit" value=discount.usageLimit min="0" placeholder="0 = không giới hạn")
            .form-group.form-group-half
              label.form-label Trạng thái
              select.form-input.form-select(name="status")
                option(value="active" selected=(discount.status === "active")) Hoạt động
                option(value="inactive" selected=(discount.status === "inactive")) Tạm dừng

          .form-row-inline
            .form-group.form-group-half
              label.form-label Ngày bắt đầu
              - var sd = discount.startDate ? new Date(discount.startDate).toISOString().slice(0,10) : ""
              input.form-input(type="date" name="startDate" value=sd)
            .form-group.form-group-half
              label.form-label Ngày hết hạn
                span.required *
              - var ed = discount.endDate ? new Date(discount.endDate).toISOString().slice(0,10) : ""
              input.form-input(type="date" name="endDate" value=ed required)

          .form-group
            label.form-label Đã sử dụng
            .status-badge.status-active(style="display: inline-block") #{discount.usedCount} lần

      .form-actions
        a.btn-cancel(href=`${prefixAdmin}/discounts`) Huỷ
        button.btn-submit(type="submit")
          i.fas.fa-save
          |  Cập nhật

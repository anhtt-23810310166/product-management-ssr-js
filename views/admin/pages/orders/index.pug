extends ../../layouts/default.pug
include ../../mixins/page-header.pug
include ../../mixins/search.pug
include ../../mixins/sort.pug
include ../../mixins/pagination.pug

block main
  div(data-crud=`${prefixAdmin}/orders` data-entity-name="đơn hàng" style="display:none")
  +pageHeader("Quản lý đơn hàng", "Quản lý tất cả đơn hàng trong hệ thống")
    .d-flex.align-items-center.gap-2
      if userPermissions && userPermissions.includes("orders_view")
        a.btn-export-excel(href=`${prefixAdmin}/orders/export` title="Xuất Excel")
          i.fas.fa-file-excel
          | Xuất Excel
      if userPermissions && userPermissions.includes("orders_change-status")
        button.btn-import-excel(type="button" data-toggle="modal" data-target="#importExcelModal" title="Nhập Excel")
          i.fas.fa-file-import
          | Nhập Excel

  //- Filter bar
  .admin-filter-bar.mb-4
    .row.align-items-center
      +search(keyword)

      //- Order Status Filter
      .col-md-4
        .order-status-filter
          select.order-status-dropdown(onchange=`window.location.href=this.value`)
            each item in orderStatuses
              option(
                value=item.status ? `${prefixAdmin}/orders?status=${item.status}` : `${prefixAdmin}/orders`
                selected=item.active
              )= item.name

      +sort(sortOptions)

  //- Orders Table
  .admin-table-wrapper
    if orders && orders.length > 0
      table.admin-table
        thead
          tr
            th.col-stt STT
            th.col-title Mã đơn
            th.col-customer Khách hàng
            th.col-items Số SP
            th.col-total Tổng tiền
            th.col-status Trạng thái
            th.col-date Ngày tạo
        tbody
          each order, index in orders
            tr.animate-in
              td.col-stt= pagination.skip + index + 1
              td.col-title
                .product-title-cell
                  span.product-name
                    a.text-primary(href=`${prefixAdmin}/orders/detail/${order._id}`) ##{order._id.toString().slice(-8).toUpperCase()}
                .product-hover-actions
                  a.hover-action-link.hover-action-detail(href=`${prefixAdmin}/orders/detail/${order._id}`) Chi tiết
                  if userPermissions && userPermissions.includes("orders_delete")
                    a.hover-action-link.hover-action-danger(href="javascript:void(0)" data-id=order._id) Xoá
              td.col-customer
                .order-customer-info
                  span.order-customer-name
                    b #{order.bookerName}
                  span.order-customer-phone= order.bookerPhone
                  if order.bookerName !== order.customerName
                    small.text-muted Nhận: #{order.customerName}
              td.col-items= order.items.length
              td.col-total
                span.order-total-price= order.totalAmount.toLocaleString() + ' ₫'
              td.col-status
                span.status-badge(class=statusMap[order.status] ? statusMap[order.status].class : "")= statusMap[order.status] ? statusMap[order.status].label : order.status
              td.col-date= order.createdAt.toLocaleDateString('vi-VN')
    else
      .admin-empty-state
        i.fas.fa-clipboard-list
        h4 Chưa có đơn hàng nào
        p Đơn hàng sẽ hiển thị khi khách hàng đặt hàng

  //- Pagination
  +pagination(pagination)

  //- Modal Import Excel
  #importExcelModal.modal.fade(tabindex="-1" role="dialog")
    .modal-dialog(role="document")
      .modal-content
        form(action=`${prefixAdmin}/orders/import` method="POST" enctype="multipart/form-data")
          .modal-header
            h5.modal-title(style="font-size: 1.1rem; font-weight: 600;") Nhập đơn hàng từ Excel
            button.close(type="button" data-dismiss="modal" aria-label="Close")
              span(aria-hidden="true") &times;
          .modal-body
            .form-group
              label.form-label.d-block(for="file" style="font-weight: 600; font-size: 13px;") Chọn file Excel (.xlsx)
              input#file.form-input.d-block.w-100(type="file" name="file" accept=".xlsx, .xls" required style="font-size: 13px;")
            p.text-muted.mt-2(style="font-size: 13px;") Tính năng Import tạm thời chỉ hỗ trợ tra cứu hoặc cập nhật tình trạng dựa trên số Mã ĐH.
          .modal-footer
            button.btn.btn-secondary(type="button" data-dismiss="modal" style="font-size: 13px;") Đóng
            button.btn.btn-primary(type="submit" style="font-size: 13px;")
              i.fas.fa-upload.mr-2
              | Tải lên

block append scripts
  script(src="/admin/js/admin-crud.js")

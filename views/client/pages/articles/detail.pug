extends ../../layouts/default

block main
  .container.py-4
    //- Breadcrumb
    nav(aria-label="breadcrumb")
      ol.breadcrumb.bg-transparent.px-0.pb-3.pt-0.mb-0.tz-breadcrumb-nav
        li.breadcrumb-item
          a.text-muted(href="/") Trang chủ
        li.breadcrumb-item
          a.text-muted(href="/articles") Tin tức & Blog
        li.breadcrumb-item.active.tz-breadcrumb-active(aria-current="page")= article.title

    .row
      //- Main content
      .col-lg-8.col-md-8
        .tz-blog-detail-card
          if article.thumbnail
            .tz-blog-detail-img(style=`background-image: url('${article.thumbnail}')`)
          .tz-blog-detail-body
            if article.featured
              span.badge.mb-3.d-inline-block(style="background: linear-gradient(90deg, #ee5a24, #ff6b6b); color: #fff; padding: 5px 12px; font-size: 0.75rem; border-radius: 4px")
                i.fas.fa-star.mr-1
                | Nổi bật

            h1.tz-blog-detail-title= article.title

            .tz-blog-detail-meta.mb-4
              if article.createdAt
                span
                  i.far.fa-clock.mr-1
                  = article.createdAt.toLocaleDateString('vi-VN')

            hr.mb-4

            .tz-blog-detail-content.content-html
              != article.description

      //- Sidebar
      .col-lg-4.col-md-4
        if relatedArticles && relatedArticles.length > 0
          .tz-blog-sidebar-card
            h5.tz-blog-sidebar-title
              i.fas.fa-newspaper.mr-2(style="color: #ee5a24")
              | Bài viết liên quan
            .tz-blog-sidebar-list
              each related in relatedArticles
                a.tz-blog-sidebar-item(href=`/articles/${related.slug}`)
                  if related.thumbnail
                    .tz-blog-sidebar-thumb(style=`background-image: url('${related.thumbnail}')`)
                  else
                    .tz-blog-sidebar-thumb.d-flex.align-items-center.justify-content-center(style="background: #f5f6fa")
                      i.fas.fa-newspaper.text-muted
                  .tz-blog-sidebar-info
                    h6.tz-blog-sidebar-item-title= related.title
                    if related.createdAt
                      small.text-muted= related.createdAt.toLocaleDateString('vi-VN')

        .mt-4
          a.d-inline-flex.align-items-center(href="/articles" style="font-size: 0.85rem; font-weight: 600; color: #ee5a24; text-decoration: none")
            i.fas.fa-arrow-left.mr-2
            | Quay lại danh sách

  //- Detail CSS
  style.
    .tz-blog-detail-card { background: var(--tz-white); border-radius: var(--tz-radius); overflow: hidden; box-shadow: var(--tz-shadow); margin-bottom: 24px; }
    .tz-blog-detail-img { width: 100%; height: 380px; background-size: cover; background-position: center; }
    .tz-blog-detail-body { padding: 28px; }
    .tz-blog-detail-title { font-size: 1.6rem; font-weight: 800; color: var(--tz-text); line-height: 1.35; margin-bottom: 16px; font-family: inherit; }
    .tz-blog-detail-meta { font-size: 0.85rem; color: var(--tz-text-secondary); }
    .tz-blog-detail-content { font-size: 0.95rem; line-height: 1.75; color: var(--tz-text); font-family: inherit; }
    .tz-blog-detail-content img { max-width: 100%; border-radius: var(--tz-radius); margin: 16px 0; }
    .tz-blog-detail-content h2, .tz-blog-detail-content h3 { margin-top: 24px; margin-bottom: 12px; color: var(--tz-text); }
    .tz-blog-detail-content p { margin-bottom: 16px; }

    .tz-blog-sidebar-card { background: var(--tz-white); border-radius: var(--tz-radius); box-shadow: var(--tz-shadow); overflow: hidden; }
    .tz-blog-sidebar-title { font-size: 0.95rem; font-weight: 700; color: var(--tz-text); padding: 18px 20px; border-bottom: 1px solid var(--tz-border); margin-bottom: 0; font-family: inherit; }
    .tz-blog-sidebar-list { padding: 0; }
    .tz-blog-sidebar-item { display: flex; align-items: center; gap: 12px; padding: 14px 20px; text-decoration: none; border-bottom: 1px solid var(--tz-border); transition: background 0.2s ease; }
    .tz-blog-sidebar-item:hover { background: var(--tz-bg); text-decoration: none; }
    .tz-blog-sidebar-thumb { width: 64px; height: 64px; border-radius: var(--tz-radius); background-size: cover; background-position: center; flex-shrink: 0; }
    .tz-blog-sidebar-info { flex: 1; min-width: 0; }
    .tz-blog-sidebar-item-title { font-size: 0.82rem; font-weight: 600; color: var(--tz-text); line-height: 1.4; margin-bottom: 4px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; font-family: inherit; }
    .tz-blog-sidebar-item:hover .tz-blog-sidebar-item-title { color: var(--tz-blue); }

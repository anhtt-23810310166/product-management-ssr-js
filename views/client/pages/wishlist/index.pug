extends ../../layouts/default.pug

include ../../mixins/product-card.pug

block main
  .container.py-4
    .d-flex.justify-content-between.align-items-center.mb-4
      div
        h4.font-weight-bold.mb-1
          | Sản phẩm yêu thích
        p.text-muted.mb-0 #{products.length} sản phẩm

    if products.length > 0
      .row
        each product in products
          .col-lg-3.col-md-4.col-6.mb-4
            +productCard(product)
    else
      .text-center.py-5
        i.far.fa-heart.text-muted(style="font-size: 64px;")
        h5.mt-3.text-muted Chưa có sản phẩm yêu thích
        p.text-muted Hãy bấm vào biểu tượng ♥ trên sản phẩm bạn thích
        a.btn.btn-primary.mt-2(href="/products") Khám phá ngay
